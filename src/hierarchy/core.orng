trait Into[U] {
    fn into(self) -> U
}

impl[T, U: From[T]] Into[U] for T {
    fn into(self) -> U {
        (U as From[T])::from(self)
    }
}

struct Package {
    root: String
    kind: Package_Kind
    dir: String
    num_requirements: Int
    requirements: [8]?Requirement
    include_dirs: [8]?String
    libs: [8]?String
    lib_dirs: [8]?String
}

impl Default for Package {
    const default: Self = Package(
        .root = "",
        .kind = .executable,
        .dir = ".",
        .num_requirements = 0,
        .requirements = [.none, .none, .none, .none, .none, .none, .none, .none],
        .include_dirs = [.none, .none, .none, .none, .none, .none, .none, .none],
        .libs = [.none, .none, .none, .none, .none, .none, .none, .none],
        .lib_dirs = [.none, .none, .none, .none, .none, .none, .none, .none]
    )
}

impl for Package {
    /// Creates a package
    fn new(root: String, kind: Package_Kind, dir: String, num_requirements: Int = 0) -> Self {
        Package(
            .root = root,
            .kind = kind,
            .dir = dir,
            .num_requirements = num_requirements,
            .requirements = [.none, .none, .none, .none, .none, .none, .none, .none],
            .include_dirs = [.none, .none, .none, .none, .none, .none, .none, .none],
            .libs = [.none, .none, .none, .none, .none, .none, .none, .none],
            .lib_dirs = [.none, .none, .none, .none, .none, .none, .none, .none]
        )
    }

    /// Creates an executable package
    fn executable(root: String) -> Self { Self::new(root, .executable, "", 0) }

    /// Creates a static library package
    fn static_library(root: String) -> Self { Self::new(root, .static_library, "") }

    /// Finds a package given a name
    /// NOTE: This is currently implemented as a builtin-function in the compiler
    fn find(src: Package_Source) -> &Self { _ = src; unreachable }

    /// Adds a package to the list of required packages
    fn requires(&mut self, name: String, other: &Package) {
        self.requirements[self.num_requirements] = .some(Requirement(name, other))
        self.num_requirements += 1
    }

    fn add_include_directory(&mut self, include_directory: String) {
        while let mut i = 0; i < 8; i += 1 {
            match self.include_dirs[i] {
                .none => {
                    self.include_dirs[i] = .some(include_directory)
                    return
                }
                _ => {}
            }
        }
        unreachable // no more space!
    }

    fn add_library(&mut self, library: String) {
        // TODO: assert not static library
        while let mut i = 0; i < 8; i += 1 {
            match self.libs[i] { 
                .none => {
                    self.libs[i] = .some(library)
                    return
                }
                _ => {}
            }
        }
        unreachable // no more space!
    }

    fn add_library_directory(&mut self, library_directory: String) {
        // TODO: assert not static library
        while let mut i = 0; i < 8; i += 1 {
            match self.lib_dirs[i] {
                .none => {
                    self.lib_dirs[i] = .some(library_directory)
                    return
                }
                _ => {}
            }
        }
        unreachable // no more space!
    }
}

enum Package_Kind {
    executable
    static_library
}

struct Requirement {
    name: String
    package: &Package
}

enum Package_Source {
    relative(String)
    git(Git_Source)
}

