trait Default {
    const default: Self
}

impl Default for Bool { const default = false }
impl Default for Int8 { const default = 0 as Self }
impl Default for Int16 { const default = 0 as Self }
impl Default for Int32 { const default = 0 as Self }
impl Default for Int64 { const default = 0 as Self }
impl Default for Word8 { const default = 0 as Self }
impl Default for Word16 { const default = 0 as Self }
impl Default for Word32 { const default = 0 as Self }
impl Default for Word64 { const default = 0 as Self }
impl Default for Float32 { const default = 0.0 as Self }
impl Default for Float64 { const default = 0.0 as Self }
impl Default for () { const default: Self = {} }
impl[T] Default for ?T { const default: ?T = .none }
impl[Err, Ok: Default] Default for Err!Ok { const default: Self = .ok((Ok as Default)::default) }
impl[T] Default for []T { const default: Self = Self::from_parts(@addr_from_word64(0), 0) }
impl[T] Default for [mut]T { const default: Self = Self::from_parts(@addr_from_word64(0), 0) }
impl[const n: Int, T: Default] Default for [n]T { 
    const default: Self = {
        let t_default = (T as Default)::default
        let mut retval: Self = undefined
        while let mut i = 0; i < n; i += 1 {
            retval[i] = t_default
        }
        retval
    }
}

