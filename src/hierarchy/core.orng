enum Ordering {
    less,
    equal,
    greater
}

trait Partial_Ord {
    fn partial_cmp(self, other: Self) -> ?Ordering

    fn lt(self, other: Self) -> Bool {
        match self.>partial_cmp(other) {
            .some(.less) => true
            _ => false
        }
    }

    fn gt(self, other: Self) -> Bool {
        match self.>partial_cmp(other) {
            .some(.greater) => true
            _ => false
        }
    }

    fn le(self, other: Self) -> Bool {
        match self.>partial_cmp(other) {
            .some(.less) => true
            .some(.equal) => true
            _ => false
        }
    }

    fn ge(self, other: Self) -> Bool {
        match self.>partial_cmp(other) {
            .some(.greater) => true
            .some(.equal) => true
            _ => false
        }
    }
}

impl[T: Primitive_Partial_Ord] Partial_Ord for T {
    fn partial_cmp(self, other: Self) -> ?Ordering {
        if @lt(self, other) {
            .some(.less)
        } else if @gt(self, other) {
            .some(.greater)
        } else if @le(self, other) {
            .some(.equal)
        } else {
            .none
        }
    }

    fn lt(self, other: Self) -> Bool { @lt(self, other) }
    fn gt(self, other: Self) -> Bool { @gt(self, other) }
    fn le(self, other: Self) -> Bool { @le(self, other) }
    fn ge(self, other: Self) -> Bool { @ge(self, other) }
}

trait Ord: Eq + Partial_Ord {
    fn cmp(self, oter: Self) -> Ordering

    fn max(self, other: Self) -> Self {
        if self < other {
            other
        } else {
            self
        }
    }

    fn min(self, other: Self) -> Self {
        if self > other {
            other
        } else {
            self
        }
    }

    fn clamp(self, low: Self, high: Self) -> Self {
        if self < low {
            low
        } else if self > high {
            high
        } else {
            self
        }
    }
}

impl[T: Primitive_Ord + Eq + Partial_Ord] Ord for T {
    fn cmp(self, other: Self) -> Ordering {
        self.>partial_cmp(other).some
    }
}

