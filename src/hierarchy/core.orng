trait Index {
    type Output
    fn index(&self, i: Int) -> Self::Output
}

trait Index_Mut: Index {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output
}

impl[T, const n: Int] Index for [n]T {
    type Output = T
    fn index(&self, i: Int) -> Self::Output { @child_addr(self, i)^ }
}

impl[T, const n: Int] Index_Mut for [n]T {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output { @child_addr_mut(self, i) }
}

impl[T] Index for []T {
    type Output = T
    fn index(&self, i: Int) -> Self::Output { @child_addr(self.data, i)^ }
}

impl[T] Index for [mut]T {
    type Output = T
    fn index(&self, i: Int) -> Self::Output { @child_addr(self.data, i)^ }
}

impl[T] Index_Mut for [mut]T {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output { @child_addr_mut(self.data, i) }
}

trait Eq {
    fn eq(self, other: Self) -> Bool
}

impl Eq for Int { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Int32 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Int16 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Int8 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Word64 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Word32 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Word16 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Word8 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Float { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl Eq for Float32 { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl[T] Eq for [*]T { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl[T] Eq for [*mut]T { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl[A: Eq, B: Eq] Eq for (A, B) { fn eq(self, other: Self) -> Bool { self.[0].>eq(other.[0]) and self.[1].>eq(other.[1]) } }
impl[A: Eq, B: Eq, C: Eq] Eq for (A, B, C) { fn eq(self, other: Self) -> Bool { self.[0].>eq(other.[0]) and self.[1].>eq(other.[1]) and self.[2].>eq(other.[2]) } }

impl Eq for String {
    fn eq(self, other: Self) -> Bool {
        if self.length != other.length {
            return false
        }
        while let mut i = 0; i < self.length; i += 1 {
            if self[i] != other[i] {
                return false
            }
        }
        true
    }
}

trait Hash: Eq {
    virtual fn hash(&self) -> Word64
}

impl Hash for String {
    virtual fn hash(&self) -> Word64 {
        let mut h: Word64 = 14695981039346656037
        const prime: Word64 = 1099511628211

        while let mut i = 0; i < self.length; i += 1 {
            h ~= (self[i] as Word64) * prime
        }

        h
    }
}

enum File_Mode {
    read
    write
    append
    read_and_write
}

trait File_System {
    virtual fn open(&mut self, path: String, mode: File_Mode = File_Mode.read) -> ?&mut dyn File
}

trait File: Writer + Reader {
    virtual fn close(&mut self)
}

trait Iterator {
    type Item

    fn next(&mut self) -> ?Self::Item
}

trait Into_Iterator {
    type Item
    type Iter: Iterator[Item = Self::Item]

    fn into_iter(self) -> Self::Iter
}

struct Slice_Iter[T] {
    items: []T
    pos: Int
}

struct Mut_Slice_Iter[T] {
    items: [mut]T
    pos: Int
}

struct Array_Iter[T, const n: Int] {
    items: [n]T
    pos: Int
}

impl[T] Iterator for Slice_Iter[T] {
    type Item = T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= self.items.length {
            return .none
        }
        let retval = self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[T] Iterator for Mut_Slice_Iter[T] {
    type Item = &mut T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= self.items.length {
            return .none
        }
        let retval = &mut self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[T, const n: Int] Iterator for Array_Iter[T, n] {
    type Item = T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= n {
            return .none
        }
        let retval = self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[I] Into_Iterator for []I {
    type Item = I
    type Iter = Slice_Iter[I]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

impl[I] Into_Iterator for [mut]I {
    type Item = &mut I
    type Iter = Mut_Slice_Iter[I]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

impl[I, const n: Int] Into_Iterator for [n]I {
    type Item = I
    type Iter = Array_Iter[I, n]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

struct Range {
    start: Int
    end: Int
}

struct Range_Iter {
    range: Range
    counter: Int
}

impl Into_Iterator for Range {
    type Item = Int
    type Iter = Range_Iter

    fn into_iter(self) -> Self::Iter {
        Range_Iter(self, self.start)
    }
}

impl Iterator for Range_Iter {
    type Item = Int

    fn next(&mut self) -> ?Int {
        match self.counter {
            {self.range.end} => .none
            _ => {
                let retval = self.counter
                self.counter += 1
                .some(retval)
            }
        }
    }
}

impl[T: Iterator] Into_Iterator for T {
    type Item = (T as Iterator)::Item
    type Iter = T

    fn into_iter(self) -> (T as Into_Iterator)::Iter {
        self
    }
}

trait Sized {
    const size: Int
}

impl Sized for Byte { const size = 1 }
impl Sized for Int { const size = 8 }
impl Sized for () { const size = 0 }
impl[T] Sized for []T { const size = 16 }

context Allocating {
    alloc: &mut dyn Allocator
}

context IO {
    writer: &mut dyn Writer
    reader: &mut dyn Reader
}

context Args {
    args: []String
}

context File_IO {
    fs: &mut dyn File_System
}
