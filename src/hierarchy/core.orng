trait Index {
    type Output
    fn index(&self, i: Int) -> &Self::Output
}

trait Index_Mut: Index {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output
}

impl[T, const n: Int] Index for [n]T {
    type Output = T
    fn index(&self, i: Int) -> &Self::Output { @child_addr(self, i) }
}

impl[T, const n: Int] Index_Mut for [n]T {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output { @child_addr_mut(self, i) }
}

impl[T] Index for []T {
    type Output = T
    fn index(&self, i: Int) -> &Self::Output {
        if i < 0 or i >= self.length { unreachable }
        @child_addr(self.data, i)
    }
}

impl[T] Index for [mut]T {
    type Output = T
    fn index(&self, i: Int) -> &Self::Output {
        if i < 0 or i >= self.length { unreachable }
        @child_addr(self.data, i)
    }
}

impl[T] Index_Mut for [mut]T {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output {
        if i < 0 or i >= self.length { unreachable }
        @child_addr_mut(self.data, i)
    }
}

impl[T] Index for [*]T {
    type Output = T
    fn index(&self, i: Int) -> &Self::Output { @child_addr(self^, i) }
}

impl[T] Index for [*mut]T {
    type Output = T
    fn index(&self, i: Int) -> &Self::Output { @child_addr(self^, i) }
}

impl[T] Index_Mut for [*mut]T {
    fn index_mut(&mut self, i: Int) -> &mut Self::Output { @child_addr_mut(self^, i) }
}

trait Partial_Eq {
    fn eq(self, other: Self) -> Bool
    fn neq(self, other: Self) -> Bool { not self.>eq(other) } 
}

trait Eq : Partial_Eq {}

impl[T: Primitive_Partial_Eq] Partial_Eq for T {
    fn eq(self, other: Self) -> Bool {
        match self {
            {other} => true
            _ => false
        }
    }
}

impl[T: Primitive_Eq + Partial_Eq] Eq for T {}

impl[T] Partial_Eq for [*]T { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl[T] Eq for [*]T {}
impl[T] Partial_Eq for [*mut]T { fn eq(self, other: Self) -> Bool { match self { {other} => true; _ => false } } }
impl[T] Eq for [*mut]T {}
impl[A: Partial_Eq, B: Partial_Eq] Partial_Eq for (A, B) { fn eq(self, other: Self) -> Bool { self.[0].>eq(other.[0]) and self.[1].>eq(other.[1]) } }
impl[A: Eq, B: Eq] Eq for (A, B) {}
impl[A: Partial_Eq, B: Partial_Eq, C: Partial_Eq] Partial_Eq for (A, B, C) { fn eq(self, other: Self) -> Bool { self.[0].>eq(other.[0]) and self.[1].>eq(other.[1]) and self.[2].>eq(other.[2]) } }
impl[A: Eq, B: Eq, C: Eq] Eq for (A, B, C) {}

impl[const n: Int, T: Partial_Eq] Partial_Eq for [n]T {
    fn eq(self, other: Self) -> Bool {
        while let mut i = 0; i < n; i += 1 {
            if self[i] != other[i] {
                return false
            }
        }
        true
    }
}
impl[const n: Int, T: Eq] Eq for [n]T {}

impl[T: Partial_Eq] Partial_Eq for []T {
    fn eq(self, other: Self) -> Bool {
        if self.length != other.length {
            return false
        }
        while let mut i = 0; i < self.length; i += 1 {
            if self[i] != other[i] {
                return false
            }
        }
        true
    }
}
impl[T: Eq] Eq for []T {}

impl[T: Partial_Eq] Partial_Eq for [mut]T {
    fn eq(self, other: Self) -> Bool {
        if self.length != other.length {
            return false
        }
        while let mut i = 0; i < self.length; i += 1 {
            if self[i] != other[i] {
                return false
            }
        }
        true
    }
}
impl[T: Eq] Eq for [mut]T {}

trait Bounded {
    const min_value: Self
    const max_value: Self
}

impl Bounded for Int8 {
    const min_value: Self = -(0x7F as Self) - 1
    const max_value: Self = 0x7F
}

impl Bounded for Int16 {
    const min_value: Self = -(0x7FFF as Self) - 1
    const max_value: Self = 0x7FFF
}

impl Bounded for Int32 {
    const min_value: Self = -(0x7FFF_FFFF as Self) - 1
    const max_value: Self = 0x7FFF_FFFF
}

impl Bounded for Int64 {
    const min_value: Self = -0x7FFF_FFFF_FFFF_FFFF - 1
    const max_value: Self = 0x7FFF_FFFF_FFFF_FFFF
}

impl Bounded for Word8 {
    const min_value: Self = 0
    const max_value: Self = 0xFF
}

impl Bounded for Word16 {
    const min_value: Self = 0
    const max_value: Self = 0xFFFF
}

impl Bounded for Word32 {
    const min_value: Self = 0
    const max_value: Self = 0xFFFF_FFFF
}

impl Bounded for Word64 {
    const min_value: Self = 0
    const max_value: Self = 0xFFFF_FFFF_FFFF_FFFF
}

impl[T] for []T {
    fn from_parts(data: [*]T, len: Int) -> Self {
        let mut retval: []T = undefined
        retval.data = data
        retval.length = len
        retval
    }

    fn subslice(self, range: Range[Int]) -> Self {
        let start = range.start orelse 0
        let end = range.end orelse self.length

        if start > end { unreachable }
        if start < 0 { unreachable }
        if start > self.length { unreachable }
        if end > self.length { unreachable }

        Self::from_parts(@addr_cast(&self.data[start]), end - start)
    }

    fn split_at(self, i: Int) -> (Self, Self) {
        (self.>subslice(0..i), self.>subslice(i..self.length))
    }

    fn is_empty(self) -> Bool { self.length == 0 }

    fn get(self, index: Int) -> ?&T {
        if index >= 0 and index < self.length {
            .some(&self[index])
        } else {
            .none
        }
    }
}

impl[T] for [mut]T {
    fn from_parts(data: [*mut]T, len: Int) -> Self {
        let mut retval: [mut]T = undefined
        retval.data = data
        retval.length = len
        retval
    }

    fn subslice(self, range: Range[Int]) -> Self {
        let start = range.start orelse 0
        let end = range.end orelse self.length

        if start > end { unreachable }
        if start < 0 { unreachable }
        if start > self.length { unreachable }
        if end > self.length { unreachable }

        Self::from_parts(@addr_cast(&mut self.data[start]), end - start)
    }

    fn split_at(self, i: Int) -> (Self, Self) {
        (self.>subslice(0..i), self.>subslice(i..self.length))
    }

    fn is_empty(self) -> Bool { self.length == 0 }

    fn get(self, index: Int) -> ?&mut T {
        if index >= 0 and index < self.length {
            .some(&mut self[index])
        } else {
            .none
        }
    }
}

impl[T: Eq] for []T {
    fn starts_with(self, prefix: []T) -> Bool {
        if prefix.length > self.length { return false }
        self.>subslice(0..prefix.length) == prefix
    }

    fn ends_with(self, suffix: []T) -> Bool {
        if suffix.length > self.length { return false }
        self.>subslice(self.length - suffix.length..self.length) == suffix
    }

    fn strip_prefix(self, prefix: []T) -> ?Self {
        if self.>starts_with(prefix) {
            .some(self.>subslice(0..prefix.length))
        } else {
            .none
        }
    }

    fn strip_suffix(self, suffix: []T) -> ?Self {
        if self.>ends_with(suffix) {
            .some(self.>subslice(self.length - suffix.length..self.length))
        } else {
            .none
        }
    }

    fn contains(self, x: &T) -> Bool {
        while let mut i = 0; i < self.length; i += 1 {
            if x^ == self[i] {
                return true
            }
        }
        false
    }
}

impl[T: Eq] for [mut]T {
    fn starts_with(self, prefix: []T) -> Bool {
        if prefix.length > self.length { return false }
        (self.>subslice(0..prefix.length) as []T) == prefix
    }

    fn ends_with(self, suffix: []T) -> Bool {
        if suffix.length > self.length { return false }
        (self.>subslice(self.length - suffix.length..self.length) as []T) == suffix
    }

    fn strip_prefix(self, prefix: []T) -> ?Self {
        if self.>starts_with(prefix) {
            .some(self.>subslice(0..prefix.length))
        } else {
            .none
        }
    }

    fn strip_suffix(self, suffix: []T) -> ?Self {
        if self.>ends_with(suffix) {
            .some(self.>subslice(self.length - suffix.length..self.length))
        } else {
            .none
        }
    }

    fn contains(self, x: &T) -> Bool {
        while let mut i = 0; i < self.length; i += 1 {
            if x^ == self[i] {
                return true
            }
        }
        false
    }
}

trait Hash: Eq {
    virtual fn hash(&self) -> Word64
}

impl Hash for String {
    virtual fn hash(&self) -> Word64 {
        let mut h: Word64 = 14695981039346656037
        const prime: Word64 = 1099511628211

        while let mut i = 0; i < self.length; i += 1 {
            h ~= @primitive_cast(self[i]) as Word64 * prime
        }

        h
    }
}

enum File_Mode {
    read
    write
    append
    read_and_write
}

trait File_System {
    virtual fn open(&mut self, path: String, mode: File_Mode = File_Mode.read) -> ?&mut dyn File
}

trait File: Writer + Reader {
    virtual fn close(&mut self)
}

trait Iterator {
    type Item

    fn next(&mut self) -> ?Self::Item

    fn filter(self, predicate: &Self::Item -> Bool) -> Filter[Self] {
        Filter[Self](self, predicate)
    }

    fn map[B](self, f: Self::Item -> B) -> Map[Self, B] {
        Map[Self, B](self, f)
    }

    fn fold[B](&mut self, mut init: B, f: (Self::Item, B) -> B) -> B {
        while true {
            match self.>next() {
                .none => {return init}
                .some(x) => init = f(x, init)
            }
        }
        init
    }
}

struct Filter[Iter: Iterator] {
    inner: Iter
    predicate: &Iter::Item -> Bool
}

impl[Iter: Iterator] Iterator for Filter[Iter] {
    type Item = Iter::Item

    fn next(&mut self) -> ?Self::Item {
        while true {
            match self.inner.>next() {
                .none => {return .none}
                .some(x) => if self.predicate(&x) {
                    return .some(x)
                }
            }
        }
        .none
    }
}

struct Map[Iter: Iterator, Codomain] {
    inner: Iter
    f: Iter::Item -> Codomain
}

impl[Iter: Iterator, Codomain] Iterator for Map[Iter, Codomain] {
    type Item = Codomain

    fn next(&mut self) -> ?Self::Item {
        match self.inner.>next() {
            .none => .none
            .some(x) => .some(self.f(x))
        }
    }
}

trait Into_Iterator {
    type Item
    type Iter: Iterator[Item = Self::Item]

    fn into_iter(self) -> Self::Iter
}

struct Slice_Iter[T] {
    items: []T
    pos: Int
}

struct Mut_Slice_Iter[T] {
    items: [mut]T
    pos: Int
}

struct Array_Iter[T, const n: Int] {
    items: [n]T
    pos: Int
}

impl[T] Iterator for Slice_Iter[T] {
    type Item = T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= self.items.length {
            return .none
        }
        let retval = self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[T] Iterator for Mut_Slice_Iter[T] {
    type Item = &mut T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= self.items.length {
            return .none
        }
        let retval = &mut self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[T, const n: Int] Iterator for Array_Iter[T, n] {
    type Item = T
    fn next(&mut self) -> ?Self::Item {
        if self.pos >= n {
            return .none
        }
        let retval = self.items[self.pos]
        self.pos += 1
        .some(retval)
    }
}

impl[I] Into_Iterator for []I {
    type Item = I
    type Iter = Slice_Iter[I]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

impl[I] Into_Iterator for [mut]I {
    type Item = &mut I
    type Iter = Mut_Slice_Iter[I]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

impl[I, const n: Int] Into_Iterator for [n]I {
    type Item = I
    type Iter = Array_Iter[I, n]

    fn into_iter(self) -> Self::Iter {
        Self::Iter(.items = self, .pos = 0)
    }
}

struct Range[Idx] {
    start: ?Idx
    end: ?Idx
}

struct Range_Iter {
    range: Range[Int]
    counter: Int
}

impl Into_Iterator for Range[Int] {
    type Item = Int
    type Iter = Range_Iter

    fn into_iter(self) -> Self::Iter {
        Range_Iter(self, self.start orelse (Int as Bounded)::min_value)
    }
}

impl Iterator for Range_Iter {
    type Item = Int

    fn next(&mut self) -> ?Int {
        let end = self.range.end orelse (Int as Bounded)::max_value
        if self.counter >= end {return .none}
        let retval = self.counter
        self.counter += 1
        .some(retval)
    }
}

impl[T: Iterator] Into_Iterator for T {
    type Item = (T as Iterator)::Item
    type Iter = T

    fn into_iter(self) -> (T as Into_Iterator)::Iter {
        self
    }
}

trait Sized {
    const size: Int
}

impl Sized for Byte { const size = 1 }
impl Sized for Int { const size = 8 }
impl Sized for () { const size = 0 }
impl[T] Sized for []T { const size = 16 }

ability Allocating = &mut dyn Allocator
ability Writing = &mut dyn Writer
ability Reading = &mut dyn Reader
ability Args = []String
ability File_IO = &mut dyn File_System
