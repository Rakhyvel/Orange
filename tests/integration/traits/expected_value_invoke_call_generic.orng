// 558
trait Get[T] {
    fn get(&self) -> T
}

struct My_Type {
    x: Int
    y: Float
}

impl Get[Int] for My_Type {
    fn get(&self) -> Int { self.x }
}

impl Get[Float] for My_Type {
    fn get(&self) -> Float { self.y }
}

fn id[S, T: Get[S]](x: T) -> S { x.>get() }

fn main() -> Int {
    let my_val = My_Type(558, 57.0)

    id[Int, My_Type](my_val)
}
