// 457
trait A {
    virtual fn a(self) -> Int
}

trait B: A {
    virtual fn b(self) -> Int
}

impl A for Int { virtual fn a(self) -> Int { self } }
impl B for Int { virtual fn b(self) -> Int { self * 2 } }

fn accept_a(x: &dyn A) -> Int { x.>a() }

fn bridge[T: B](x: &T) -> Int { accept_a(&x) }

fn main() -> Int { bridge[Int](&457) }