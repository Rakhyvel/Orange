// 560
trait Get[T] {
    fn get(&mut self) -> T
}

struct My_Type {
    x: Int
    y: Float
}

impl Get[()] for My_Type {
    fn get(&mut self) -> () { self.x *= 4 }
}

impl Get[Int] for My_Type {
    fn get(&mut self) -> Int { self.x *= 4; self.x }
}

fn main() -> Int {
    let mut my_val = My_Type(140, 57.0)

    let x: () = my_val.>get()
    _ = x

    my_val.x
}
