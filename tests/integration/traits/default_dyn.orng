// 506
trait I_Give_A_Default {
    virtual fn required(&self) -> Int

    virtual fn provided(&self) -> Int {
        self.>required()
    }
}

impl I_Give_A_Default for Int {
    virtual fn required(&self) -> Int { self^ }
}

fn call_provided(x: &dyn I_Give_A_Default) -> Int {
    x.>provided()
}

fn main() -> Int {
    let x = 506
    call_provided(&x)
}