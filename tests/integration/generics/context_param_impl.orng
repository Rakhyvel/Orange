// 588
context My_Context {
    x: Int
}

fn main() -> Int {
    let doer = Doer[Int, My_Context]()
    _ = doer
    with My_Context(2) {
        doer.>do_twice(scale, 147)
    }
}

struct Doer[T, context C] {}

impl[T, context C] for Doer[T, C] {
    fn do_twice(f: T -> T with C, x: T) -> T with C {
        f(f(x))
    }
}

fn scale(x: Int) -> Int with My_Context { x * My_Context.x }
