// 0
// Regression: monomorphizing a `[mut]K`-receiver associated function when the generic
// param K is itself a slice type must keep K's slice level, not collapse to its element
struct Box[K] {
    keys: [mut]K
}

impl[K] for Box[K] {
    fn init() -> Self {
        Self(.keys = ([mut]K)::from_parts(0 as [*mut]K, 0))
    }
}

fn main() -> Int {
    let b = Box[[]Byte]::init()
    b.keys.length
}
