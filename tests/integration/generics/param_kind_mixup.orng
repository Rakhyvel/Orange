// 585
fn main() -> Int {
    let mut arr = [1, 2, 3]
    fn f(x: Int) -> Int with My_Ability { x * My_Ability }
    with My_Ability(195) {
        map_array[Int, 3, My_Ability](f, &mut arr)
    }
    arr[2]
}

ability My_Ability = Int

fn map_array[T, const n: Int, ability C](f: T -> T with C, xs: &mut [n]T) with C {
    for i in 0..n {
        xs[i] = f(xs[i])
    }
}
