// 609
trait Pairer {
    fn f[T, S](x: []T, y: S) -> (T, S)
}

struct Box {}
impl Pairer for Box {
    fn f[S, T](x: []S, y: T) -> (S, T) { (x[0], y) }
}

fn main() -> Int {
    let bools = [true, false, false]
    let (s, t) = (Box as Pairer)::f[Bool, Int](&bools, 609)
    if s {
        t
    } else {
        unreachable
    }
}