// 250
struct My_Type {
    x: Int
    y: Int
}

impl core::Default for My_Type { const default = My_Type(450, 50) }

fn main() -> Int {
    add_fields(2)
}

// A way to provide a default value for a type
// This is _really_ useful for generic functions (soon!)
fn add_fields(scale: Int, mt: My_Type = My_Type::default) -> Int {
    (mt.x + mt.y) / scale
}
