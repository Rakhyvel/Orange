// 450
trait Give_Num {
    virtual fn get_num(&mut self) -> Int
}

struct Impler {
    x: Int
}
impl Give_Num for Impler {
    virtual fn get_num(&mut self) -> Int {
        self.x += 400
        self.x
    }
}

context Num {
    num_getter: &mut dyn Give_Num
}

fn get_num[T](x: Int) -> Int with Num {
    x + Num.num_getter.>get_num()
}

struct Wrapper[T] {}
impl[T] for Wrapper[T] {
    fn run(self) -> Int with Num {
        _ = self
        get_num[T](50)
    }
}

fn main() -> Int {
    let mut impler = Impler(0)
    let wrapper = Wrapper[Int]()
    with Num(.num_getter = &mut impler) {
        wrapper.>run()
    }
}
