// 5164
fn main() -> Int {
    with Ctx_A(40), Ctx_B(50) {
        (do_twice[Int, Ctx_A](a, 1)   // + 81
        + do_twice[Int, Ctx_B](b, 2)  // + 5000
        + do_twice[Int, Ctx_A](a, 3)) // + 83
    }
}

fn a(x: Int) -> Int with Ctx_A { x + Ctx_A }
fn b(x: Int) -> Int with Ctx_B { x * Ctx_B }

abilityCtx_A = Int

abilityCtx_B = Int

fn do_twice[T, abilityC](f: T -> T with C, x: T) -> T with C {
    f(f(x))
}
