// 805
fn main() -> Int {
    with Ctx_Alias(7) {
        use_direct() + use_alias() + do_twice[Int, Ctx_Alias](scale, 2)
    }
}

type Ctx_Alias = My_Ability

abilityMy_Ability = Int

fn use_direct() -> Int with My_Ability { My_Ability * 50 }

fn use_alias() -> Int with Ctx_Alias { Ctx_Alias * 51 }

fn scale(v: Int) -> Int with My_Ability { v * My_Ability }

fn do_twice[T, abilityC](f: T -> T with C, x: T) -> T with C {
    f(f(x))
}
