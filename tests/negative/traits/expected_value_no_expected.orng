trait My_From[T] {
    fn from(other: T) -> Self
}

struct My_Type {
    a: Int
}

impl My_From[Int] for My_Type {
    fn from(other: Int) -> Self { My_Type(other) }
}

fn main() -> Int {
    let x = My_From[Int]::from(5)
    x.a
}
