trait Get[T] {
    fn get(&self) -> T
}

struct My_Type {
    x: Int
    y: Float
}

impl Get[Int] for My_Type {
    fn get(&self) -> Int { self.x }
}

impl Get[Float] for My_Type {
    fn get(&self) -> Float { self.y }
}

fn main() -> Int {
    let v = My_Type(1, 2.0)
    let b: Bool = v.>get()
    if b { 1 } else { 0 }
}
