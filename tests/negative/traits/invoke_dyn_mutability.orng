trait Lol {
    virtual fn lmao(&mut self) -> ()
}

impl Lol for Int {
    virtual fn lmao(&mut self) -> () {
        self^ = 30
    }
}

fn main() -> Int {
    let x = 5
    f(&x)
    x
}

fn f(x: &dyn Lol) -> () {
    x.>lmao()
}