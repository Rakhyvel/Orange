trait My_Foo {
    fn bar(self, x: &Int) -> Int
}

impl My_Foo for Int {
    fn bar(self, x: &Int) -> Int { x^ }
}

fn main() -> Int {
    let n: Int = 5
    let x: Int = 10
    x.>bar(n)
}
