trait Get_A {
    fn get(&self) -> Int
}

trait Get_B {
    fn get(&self) -> Int
}

struct My_Type {
    x: Int
}

impl Get_A for My_Type {
    fn get(&self) -> Int { self.x }
}

impl Get_B for My_Type {
    fn get(&self) -> Int { self.x + 1 }
}

fn main() -> Int {
    let v = My_Type(1)
    let a: Int = v.>get()
    a
}
